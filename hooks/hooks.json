{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-}}\"; if [ -n \"$PLUGIN_ROOT\" ]; then python3 \"$PLUGIN_ROOT/hooks/scripts/session_start.py\"; else printf '[project-protocol] Invoke /ceo, /worker, or /solo; then run /recap.\\n'; fi"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-}}\"; if [ -n \"$PLUGIN_ROOT\" ]; then python3 \"$PLUGIN_ROOT/hooks/scripts/pre_compact.py\"; fi"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '[project-protocol] Compaction complete. Continue the human-invoked role and run /recap before acting.\\n'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-}}\"; if [ -n \"$PLUGIN_ROOT\" ]; then python3 \"$PLUGIN_ROOT/hooks/scripts/stop_warning.py\"; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_ROOT=\"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-}}\"; if [ -n \"$PLUGIN_ROOT\" ]; then python3 \"$PLUGIN_ROOT/hooks/scripts/post_write.py\"; fi"
          }
        ]
      }
    ]
  }
}
